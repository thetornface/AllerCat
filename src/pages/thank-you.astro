---
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { getEntry } from 'astro:content';

const homeEntry = await getEntry('home', 'home');
const contact = homeEntry!.data.contact;
---

<BaseLayout
  title="Спасибо за заявку — AllerCat"
  description="Мы получили вашу заявку и скоро свяжемся с вами."
  noIndex={true}
>
  <Nav />
  <main id="content">
    <div class="thankyou-wrap">
      <div class="thankyou-icon">🐱</div>
      <h1 style="font-size: clamp(1.75rem, 4vw, 2.5rem);">Заявка получена!</h1>
      <p style="max-width: 480px; text-align: center; color: var(--fg-muted);">
        Спасибо! Мы получили вашу заявку и скоро свяжемся с вами для уточнения деталей заказа.
      </p>
      <p style="font-size: 0.9rem; color: var(--fg-subtle); text-align: center;">
        Мы не списываем оплату автоматически. Заказ подтверждается только после разговора с вами.
      </p>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
        <a class="button" href="/">На главную</a>
        <a class="button button--secondary" href={contact.telegram} target="_blank" rel="noopener">
          Написать в Telegram
        </a>
      </div>
    </div>
  </main>
  <Footer contact={contact} />
</BaseLayout>
