---
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { getEntry } from 'astro:content';
import facts from '../data/facts.json';
import slides from '../data/slides.json';

const homeEntry = await getEntry('home', 'home');
const data = homeEntry!.data;

const timeFilters = [
  { label: 'Все', value: 'all' },
  { label: '1 мин', value: '1' },
  { label: '2 мин', value: '2' },
  { label: '3 мин', value: '3' },
];

const catFilters = [
  { ico: '🐾', label: 'Все факты',     value: 'all' },
  { ico: '🧬', label: 'Аллерген',      value: 'allergen' },
  { ico: '🐱', label: 'Кошки',         value: 'cats' },
  { ico: '🔬', label: 'Наука',         value: 'science' },
  { ico: '🏠', label: 'Жизнь с кошкой', value: 'lifestyle' },
  { ico: '💊', label: 'Лечение',       value: 'treatment' },
];

const shops = [
  { ico: '🟠', name: 'Ozon' },
  { ico: '🟣', name: 'Wildberries' },
  { ico: '🟡', name: 'Яндекс Маркет' },
  { ico: '🐾', name: 'Petshop' },
  { ico: '🛍️', name: 'Самокат' },
  { ico: '🛒', name: 'Мегамаркет' },
];
---

<BaseLayout
  title="AllerCat — Живите с кошкой. Без аллергии."
  description="AllerCat — российская кормовая добавка на основе IgY-антител. Помогает снижать активный аллерген Fel d 1 на шерсти кошки — в среднем на 47% к 3-й неделе ежедневного применения (Satyaraj et al., 2019)."
>
  <Nav />

  <main id="content">

    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <span class="hero-badge">🇷🇺 Российский бренд · IgY-технология</span>
        <h1>Добавляйте <em>заботу</em><br/>в&nbsp;каждую миску</h1>
        <p class="hero-sub">AllerCat — порошковая добавка с&nbsp;IgY-антителами, которые связывают аллерген Fel&nbsp;d&nbsp;1 ещё в&nbsp;слюне кошки. По&nbsp;данным исследования Satyaraj&nbsp;et&nbsp;al., 2019 — среднее снижение активного Fel&nbsp;d&nbsp;1 на&nbsp;шерсти на&nbsp;47% уже к&nbsp;3-й&nbsp;неделе.</p>
        <div class="hero-cta">
          <button id="heroPreorderBtn" type="button" class="btn btn-p">Оформить предзаказ</button>
          <a href="#facts" class="btn btn-ghost">Интересные факты</a>
        </div>
      </div>
      <div class="hero-imgs">
        <div class="hero-img-wrap">
          <div class="bg-img bg-jar"></div>
          <span class="hero-img-label">100&nbsp;г порошка</span>
        </div>
        <div class="hero-img-wrap center">
          <div class="bg-img bg-cat"></div>
          <span class="hero-img-label">−47% к 3-й неделе</span>
        </div>
        <div class="hero-img-wrap">
          <div class="bg-img bg-jar"></div>
          <span class="hero-img-label">30 дней курса</span>
        </div>
      </div>
    </section>

    <!-- STATS STRIP -->
    <div class="strip">
      <div class="strip-inner">
        <div class="strip-stat"><div class="num">−47%</div><div class="lbl">аллергена в среднем (3 нед.)</div></div>
        <div class="strip-div"></div>
        <div class="strip-stat"><div class="num">3–6</div><div class="lbl">недель до устойчивого эффекта</div></div>
        <div class="strip-div"></div>
        <div class="strip-stat"><div class="num">127</div><div class="lbl">довольных семей</div></div>
        <div class="strip-div"></div>
        <div class="strip-stat"><div class="num">100%</div><div class="lbl">натуральный состав</div></div>
      </div>
    </div>

    <!-- FILTERS + FACTS GRID -->
    <section id="facts">
      <div class="filters-section">
        <div class="wrap">
          <div class="filters-top">
            <h2>Интересные факты<br/>об аллергии и кошках</h2>
            <div class="search-wrap">
              <svg class="search-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <circle cx="11" cy="11" r="8"/>
                <path d="M21 21l-4.35-4.35"/>
              </svg>
              <input type="search" id="searchInput" placeholder="Поиск фактов…" />
            </div>
          </div>

          <div class="time-filters" id="timeFilters">
            {timeFilters.map((f) => (
              <button class={`time-btn${f.value === 'all' ? ' active' : ''}`} data-time={f.value} type="button">{f.label}</button>
            ))}
          </div>

          <div class="cat-filters" id="catFilters">
            {catFilters.map((f) => (
              <button class={`cat-btn${f.value === 'all' ? ' active' : ''}`} data-cat={f.value} type="button">
                <span class="ico">{f.ico}</span>{f.label}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div class="cards-section">
        <div class="wrap">
          <div class="cards-grid stagger" id="cardsGrid">
            {facts.map((card) => (
              <div class="fact-card" data-cat={card.cat} data-time={card.time} data-idx={card.idx}>
                <div class="card-img">
                  <div class={`card-img-inner ${card.bg}`}>
                    <img
                      src={`/assets/images/cards/${card.icon}.webp`}
                      alt=""
                      loading="lazy"
                      decoding="async"
                      width="800"
                      height="800"
                    />
                  </div>
                  <span class="card-num">Факт №{card.idx + 1}</span>
                </div>
                <div class="card-body">
                  <div class="card-cat"><span>{card.catIcon}</span>{card.catLabel}</div>
                  <div class="card-title">{card.title}</div>
                  <div class="card-text">{card.text}</div>
                </div>
                <div class="card-foot">
                  <div class="card-time">⏱ {card.time} мин</div>
                  <span class="card-tag">{card.tag}</span>
                </div>
              </div>
            ))}
          </div>

          <div id="noResults" class="no-results" style="display:none">
            <div class="icon">🔍</div>
            <h3>Ничего не найдено</h3>
            <p>Попробуйте другой запрос или сбросьте фильтры</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SLIDER (how it works) -->
    <section class="slider-section" id="how">
      <div class="slider-label reveal">
        <span class="eyebrow">Как работает</span>
        <h2>Путь от миски до облегчения</h2>
      </div>

      <div class="slider-track-wrap">
        <div class="slider-track" id="sliderTrack">
          {slides.map((s) => (
            <div class="slide-card">
              <div class={`slide-img ${s.bg}`}>
                <img
                  src={`/assets/images/cards/${s.icon}.webp`}
                  alt=""
                  loading="lazy"
                  decoding="async"
                  width="800"
                  height="800"
                />
              </div>
              <div class="slide-body">
                <h4>{s.title}</h4>
                <p>{s.text}</p>
                <span class="slide-tag">{s.tag}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="slider-nav">
        <button class="sl-btn" id="slPrev" type="button" aria-label="Назад">←</button>
        <button class="sl-btn" id="slNext" type="button" aria-label="Вперёд">→</button>
      </div>
    </section>

    <!-- BUY SECTION -->
    <section class="buy-section" id="buy">
      <div class="wrap">
        <div class="buy-inner">
          <div class="buy-text reveal">
            <h2>AllerCat 100&nbsp;г — курс на&nbsp;месяц</h2>
            <p>Порошковая кормовая добавка с&nbsp;IgY-антителами. Связывает аллерген Fel&nbsp;d&nbsp;1 ещё в&nbsp;слюне кошки и&nbsp;помогает снижать его активный уровень на&nbsp;шерсти — без влияния на&nbsp;вкус корма и&nbsp;самочувствие животного.</p>
            <div class="buy-price">
              <span class="price-big">2&nbsp;690&nbsp;₽</span>
              <span class="price-old">3&nbsp;200&nbsp;₽</span>
              <span class="price-badge">−16%</span>
            </div>
            <div style="display:flex;gap:12px;margin-bottom:32px;flex-wrap:wrap">
              <button class="btn btn-p" id="buyBtn" type="button">Оформить предзаказ</button>
              <button class="btn btn-s" id="detailsBtn" type="button">Подробнее</button>
            </div>
            {/* Маркетплейсы временно скрыты — пригодятся, когда продукт выйдет в продажу.
            <p style="color:var(--muted);font-size:.88rem;margin-bottom:16px;font-weight:600">🛒 Купить в маркетплейсах:</p>
            <div class="buy-shops">
              {shops.map((s) => (
                <div class="shop-tile">
                  <div class="shop-ico">{s.ico}</div>
                  <div class="shop-name">{s.name}</div>
                </div>
              ))}
            </div>
            */}
          </div>
          <div class="buy-img reveal">
            <div class="bg-img bg-cat"></div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer contact={data.contact} />

  <!-- ARTICLE MODAL -->
  <div class="art-modal" id="artModal">
    <div class="art-inner" id="artInner">
      <!-- rendered by JS -->
    </div>
  </div>

  <!-- PRODUCT DETAILS MODAL -->
  <div class="info-modal" id="infoModal" aria-hidden="true">
    <div class="info-inner" role="dialog" aria-modal="true" aria-labelledby="infoTitle">
      <button class="info-close" id="infoClose" type="button" aria-label="Закрыть">✕</button>
      <span class="info-eyebrow">Кратко о продукте</span>
      <h2 id="infoTitle">AllerCat 100&nbsp;г — курс на месяц</h2>
      <p>Порошковая кормовая добавка с&nbsp;IgY-антителами против Fel&nbsp;d&nbsp;1 — главного аллергена кошек, содержащегося в&nbsp;слюне. Антитела связывают молекулы аллергена ещё в&nbsp;пасти животного и&nbsp;помогают снижать его активную форму на&nbsp;шерсти.</p>

      <h3>Состав</h3>
      <p>Сушёный яичный желток с&nbsp;анти-Fel&nbsp;d&nbsp;1 IgY-антителами, без вкусовых добавок. Не содержит лекарственных веществ.</p>

      <h3>Как применять</h3>
      <ul>
        <li>Полчайной ложки на&nbsp;1&nbsp;кг веса кошки в&nbsp;день.</li>
        <li>Смешать с&nbsp;привычным сухим или влажным кормом.</li>
        <li>Применять ежедневно — пропуски снижают эффект.</li>
        <li>Первые изменения обычно заметны к&nbsp;3-й неделе, устойчивый эффект — к&nbsp;6-й.</li>
      </ul>

      <h3>Кому подходит</h3>
      <ul>
        <li>Семьям с&nbsp;чувствительностью к&nbsp;кошачьему аллергену.</li>
        <li>Тем, кто не&nbsp;хочет купать кошку и&nbsp;использовать спреи.</li>
        <li>Любым здоровым кошкам — продукт безопасен и&nbsp;не&nbsp;влияет на&nbsp;вкус корма.</li>
      </ul>

      <p class="info-foot">Не&nbsp;является лекарственным средством. Перед применением желательно проконсультироваться с&nbsp;ветеринаром.</p>

      <div class="info-actions">
        <button class="btn btn-p" id="infoPreorderBtn" type="button">Оформить предзаказ</button>
        <button class="btn btn-s" id="infoClose2" type="button">Закрыть</button>
      </div>
    </div>
  </div>

  <!-- PREORDER MODAL -->
  <div class="preorder-modal" id="preorderModal" aria-hidden="true">
    <div class="preorder-inner" role="dialog" aria-modal="true" aria-labelledby="preorderTitle">
      <button class="preorder-close" id="preorderClose" type="button" aria-label="Закрыть">✕</button>
      <span class="preorder-eyebrow">Предзаказ</span>
      <h2 id="preorderTitle">Скоро будет доступно</h2>
      <p class="preorder-lead">AllerCat ещё&nbsp;не в&nbsp;открытой продаже. Оставьте контакты — мы напишем первыми, как только продукт появится.</p>

      <form id="preorderForm" class="preorder-form" novalidate>
        <label class="preorder-field">
          <span>Имя</span>
          <input type="text" name="name" id="prName" autocomplete="given-name" placeholder="Как к вам обращаться" required />
        </label>
        <label class="preorder-field">
          <span>Почта или телефон</span>
          <input type="text" name="contact" id="prContact" autocomplete="email" placeholder="example@mail.ru или +7…" required />
        </label>
        <label class="preorder-field">
          <span>Ссылка на соцсети <em>(необязательно)</em></span>
          <input type="text" name="social" id="prSocial" placeholder="t.me/, instagram.com/…" />
        </label>

        <p class="preorder-consent">
          Отправляя форму, вы соглашаетесь с&nbsp;<a href="/privacy" target="_blank" rel="noopener">политикой конфиденциальности</a> и&nbsp;<a href="/consent" target="_blank" rel="noopener">обработкой персональных данных</a>.
        </p>

        <div class="preorder-error" id="preorderError" hidden></div>

        <button class="btn btn-p preorder-submit" id="preorderSubmit" type="submit">Оформить предзаказ</button>
      </form>

      <div class="preorder-success" id="preorderSuccess" hidden>
        <div class="preorder-success-emoji">🐾</div>
        <h3>Спасибо!</h3>
        <p>Ваша заявка получена. Мы свяжемся с вами, как только AllerCat появится в&nbsp;продаже.</p>
        <button class="btn btn-s" id="preorderDone" type="button">Закрыть</button>
      </div>
    </div>
  </div>

  <div class="toast" id="toast"></div>

  <script is:inline define:vars={{ facts }}>
    // Cards interactivity
    const CARDS = Array.from(document.querySelectorAll('.fact-card'));

    // ─── FILTERS ─────────────────────────────────────────────
    let activeCat = 'all', activeTime = 'all', searchQ = '';

    function filterCards() {
      let any = false;
      CARDS.forEach((c) => {
        const cat = c.dataset.cat;
        const time = parseInt(c.dataset.time);
        const text = c.innerText.toLowerCase();
        const matchCat  = activeCat === 'all' || cat === activeCat;
        const matchTime = activeTime === 'all' || time === parseInt(activeTime);
        const matchQ    = !searchQ || text.includes(searchQ);
        const show = matchCat && matchTime && matchQ;
        c.style.display = show ? '' : 'none';
        if (show) any = true;
      });
      const noResults = document.getElementById('noResults');
      if (noResults) noResults.style.display = any ? 'none' : 'block';
    }

    document.querySelectorAll('.cat-btn').forEach((b) => {
      b.addEventListener('click', () => {
        document.querySelectorAll('.cat-btn').forEach((x) => x.classList.remove('active'));
        b.classList.add('active');
        activeCat = b.dataset.cat;
        filterCards();
      });
    });

    document.querySelectorAll('.time-btn').forEach((b) => {
      b.addEventListener('click', () => {
        document.querySelectorAll('.time-btn').forEach((x) => x.classList.remove('active'));
        b.classList.add('active');
        activeTime = b.dataset.time;
        filterCards();
      });
    });

    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQ = e.target.value.toLowerCase().trim();
        filterCards();
      });
    }

    // ─── ARTICLE MODAL ────────────────────────────────────────
    function openArticle(idx) {
      const a = facts[idx];
      if (!a) return;
      const inner = document.getElementById('artInner');
      inner.innerHTML = `
        <div class="art-hero">
          <img class="art-hero-img" src="/assets/images/cards/${a.icon}.webp" alt="" loading="eager" decoding="async" />
          <button class="art-close-btn" id="artClose" type="button" aria-label="Закрыть">✕</button>
          <div class="art-meta">
            <span class="art-cat-badge">${a.catIcon} ${a.catLabel}</span>
            <span class="art-time-badge">⏱ ${a.time} мин чтения</span>
          </div>
          <h2>${a.title}</h2>
        </div>
        <div class="art-body">
          <p>${a.text}</p>
          <p>Это один из ${facts.length} фактов в нашей базе. AllerCat — российская кормовая добавка на основе IgY-антител: они связывают аллерген Fel d 1 в слюне кошки. По данным Satyaraj et al. (2019) среднее снижение активного Fel d 1 на шерсти составляет 47% к 3-й неделе ежедневного применения.</p>
        </div>
        <div class="art-foot">
          <small>Кормовая добавка AllerCat. Не является лекарственным средством.</small>
          <button class="btn btn-p" id="artBuy" type="button">Оформить предзаказ</button>
          <button class="btn btn-s" id="artClose2" type="button">Закрыть</button>
        </div>`;
      document.getElementById('artModal').classList.add('open');
      document.body.style.overflow = 'hidden';
      document.getElementById('artClose').onclick  = closeArticle;
      document.getElementById('artClose2').onclick = closeArticle;
      document.getElementById('artBuy').onclick = () => { closeArticle(); addToCart(); };
    }
    function closeArticle() {
      document.getElementById('artModal').classList.remove('open');
      document.body.style.overflow = '';
    }
    document.getElementById('artModal').addEventListener('click', (e) => {
      if (e.target === document.getElementById('artModal')) closeArticle();
    });

    CARDS.forEach((c) => {
      c.addEventListener('click', () => openArticle(parseInt(c.dataset.idx)));
    });

    // ─── PRODUCT INFO MODAL ──────────────────────────────────
    const infoModal = document.getElementById('infoModal');
    function openInfo()  { infoModal.classList.add('open');    infoModal.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; }
    function closeInfo() { infoModal.classList.remove('open'); infoModal.setAttribute('aria-hidden', 'true');  document.body.style.overflow = ''; }
    document.getElementById('detailsBtn')?.addEventListener('click', openInfo);
    document.getElementById('infoClose')?.addEventListener('click', closeInfo);
    document.getElementById('infoClose2')?.addEventListener('click', closeInfo);
    infoModal?.addEventListener('click', (e) => { if (e.target === infoModal) closeInfo(); });

    // ─── PREORDER MODAL ──────────────────────────────────────
    /**
     * Google Apps Script Web App endpoint that appends rows to the
     * preorders spreadsheet. Source script + setup steps live in
     * docs/apps-script/. Redeployment URL changes only when a fresh
     * deployment is created (not on code-only redeploys).
     */
    const PREORDER_ENDPOINT = 'https://script.google.com/macros/s/AKfycbxYMQd1NbTbB7zu3tfrRVUk98VtF1sqxFliR1HRy2zzHm3cG-mvyZXQGgV4d-RDRj0P/exec';

    const preorderModal = document.getElementById('preorderModal');
    const preorderForm = document.getElementById('preorderForm');
    const preorderSuccess = document.getElementById('preorderSuccess');
    const preorderError = document.getElementById('preorderError');
    const preorderSubmit = document.getElementById('preorderSubmit');

    function openPreorder() {
      preorderForm.hidden = false;
      preorderSuccess.hidden = true;
      preorderError.hidden = true;
      preorderError.textContent = '';
      preorderModal.classList.add('open');
      preorderModal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      setTimeout(() => document.getElementById('prName')?.focus(), 80);
    }
    function closePreorder() {
      preorderModal.classList.remove('open');
      preorderModal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    document.getElementById('preorderClose')?.addEventListener('click', closePreorder);
    document.getElementById('preorderDone')?.addEventListener('click', closePreorder);
    preorderModal?.addEventListener('click', (e) => { if (e.target === preorderModal) closePreorder(); });

    document.getElementById('heroPreorderBtn')?.addEventListener('click', openPreorder);
    document.getElementById('buyBtn')?.addEventListener('click', openPreorder);
    document.getElementById('infoPreorderBtn')?.addEventListener('click', () => { closeInfo(); openPreorder(); });
    document.getElementById('cartBtn')?.addEventListener('click', openPreorder);

    preorderForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      preorderError.hidden = true;
      preorderError.textContent = '';

      const name    = document.getElementById('prName').value.trim();
      const contact = document.getElementById('prContact').value.trim();
      const social  = document.getElementById('prSocial').value.trim();

      if (!name)    { preorderError.textContent = 'Укажите, как к вам обращаться.';     preorderError.hidden = false; return; }
      if (!contact) { preorderError.textContent = 'Оставьте почту или телефон для связи.'; preorderError.hidden = false; return; }

      // Soft sanity check: contact must look like email OR contain ≥6 digits.
      const looksLikeEmail = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(contact);
      const digitCount     = (contact.match(/\d/g) || []).length;
      if (!looksLikeEmail && digitCount < 6) {
        preorderError.textContent = 'Похоже, контакт указан не полностью. Проверьте email или телефон.';
        preorderError.hidden = false;
        return;
      }

      preorderSubmit.disabled = true;
      preorderSubmit.textContent = 'Отправляем…';

      const payload = {
        name,
        contact,
        social,
        page: window.location.href,
        userAgent: navigator.userAgent,
        ts: new Date().toISOString(),
      };

      try {
        if (!PREORDER_ENDPOINT.includes('REPLACE_WITH_YOUR_DEPLOYMENT_ID')) {
          // text/plain avoids CORS preflight against Apps Script
          await fetch(PREORDER_ENDPOINT, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'text/plain;charset=utf-8' },
            body: JSON.stringify(payload),
          });
        } else {
          console.warn('[preorder] PREORDER_ENDPOINT не настроен. Заявка не отправлена.', payload);
        }
        preorderForm.hidden = true;
        preorderSuccess.hidden = false;
        preorderForm.reset();
      } catch (err) {
        console.error(err);
        preorderError.textContent = 'Не удалось отправить. Попробуйте позже или напишите в Telegram @AllerCat.';
        preorderError.hidden = false;
      } finally {
        preorderSubmit.disabled = false;
        preorderSubmit.textContent = 'Оформить предзаказ';
      }
    });

    // ─── ESC TO CLOSE MODALS ─────────────────────────────────
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      if (preorderModal?.classList.contains('open'))      closePreorder();
      else if (infoModal?.classList.contains('open'))     closeInfo();
      else if (document.getElementById('artModal')?.classList.contains('open')) closeArticle();
    });

    // ─── TOAST ───────────────────────────────────────────────
    let toastT;
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = '✓ ' + msg;
      t.classList.add('show');
      clearTimeout(toastT);
      toastT = setTimeout(() => t.classList.remove('show'), 2400);
    }

    // ─── SLIDER ──────────────────────────────────────────────
    const track = document.getElementById('sliderTrack');
    let slIdx = 0;
    const SLIDE_W = 320;

    function updateSlider() {
      if (!track) return;
      const max = track.children.length - Math.floor(track.parentElement.offsetWidth / SLIDE_W);
      slIdx = Math.max(0, Math.min(slIdx, max));
      track.style.transform = `translateX(-${slIdx * SLIDE_W}px)`;
    }
    const slNext = document.getElementById('slNext');
    const slPrev = document.getElementById('slPrev');
    if (slNext) slNext.addEventListener('click', () => { slIdx++; updateSlider(); });
    if (slPrev) slPrev.addEventListener('click', () => { slIdx = Math.max(0, slIdx - 1); updateSlider(); });
    window.addEventListener('resize', updateSlider);

    // ─── SCROLL REVEAL ───────────────────────────────────────
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('on'); });
    }, { threshold: 0.05 });
    document.querySelectorAll('.reveal,.stagger').forEach((el) => obs.observe(el));
    setTimeout(() => {
      document.querySelectorAll('.reveal,.stagger').forEach((el) => el.classList.add('on'));
    }, 400);
  </script>

</BaseLayout>
