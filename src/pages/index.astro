---
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { getEntry } from 'astro:content';
import facts from '../data/facts.json';
import slides from '../data/slides.json';
import { ICONS } from '../lib/icons';

const homeEntry = await getEntry('home', 'home');
const data = homeEntry!.data;

const timeFilters = [
  { label: 'Все', value: 'all' },
  { label: '1 мин', value: '1' },
  { label: '2 мин', value: '2' },
  { label: '3 мин', value: '3' },
];

const catFilters = [
  { ico: '🐾', label: 'Все факты',     value: 'all' },
  { ico: '🧬', label: 'Аллерген',      value: 'allergen' },
  { ico: '🐱', label: 'Кошки',         value: 'cats' },
  { ico: '🔬', label: 'Наука',         value: 'science' },
  { ico: '🏠', label: 'Жизнь с кошкой', value: 'lifestyle' },
  { ico: '💊', label: 'Лечение',       value: 'treatment' },
];

const shops = [
  { ico: '🟠', name: 'Ozon' },
  { ico: '🟣', name: 'Wildberries' },
  { ico: '🟡', name: 'Яндекс Маркет' },
  { ico: '🐾', name: 'Petshop' },
  { ico: '🛍️', name: 'Самокат' },
  { ico: '🛒', name: 'Мегамаркет' },
];
---

<BaseLayout
  title="AllerCat — Живите с кошкой. Без аллергии."
  description="AllerCat — российская кормовая добавка на основе IgY-антител. Помогает снижать активный аллерген Fel d 1 на шерсти кошки — в среднем на 47% к 3-й неделе ежедневного применения (Satyaraj et al., 2019)."
>
  <Nav />

  <main id="content">

    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <span class="hero-badge">🇷🇺 Российский бренд · IgY-технология</span>
        <h1>Добавляйте <em>заботу</em><br/>в&nbsp;каждую миску</h1>
        <p class="hero-sub">AllerCat — порошковая добавка с&nbsp;IgY-антителами, которые связывают аллерген Fel&nbsp;d&nbsp;1 ещё в&nbsp;слюне кошки. По&nbsp;данным исследования Satyaraj&nbsp;et&nbsp;al., 2019 — среднее снижение активного Fel&nbsp;d&nbsp;1 на&nbsp;шерсти на&nbsp;47% уже к&nbsp;3-й&nbsp;неделе.</p>
        <div class="hero-cta">
          <a href="#buy" class="btn btn-p">Купить — 2&nbsp;690&nbsp;₽</a>
          <a href="#facts" class="btn btn-ghost">Интересные факты</a>
        </div>
      </div>
      <div class="hero-imgs">
        <div class="hero-img-wrap">
          <div class="bg-img bg-jar"></div>
          <span class="hero-img-label">100&nbsp;г порошка</span>
        </div>
        <div class="hero-img-wrap center">
          <div class="bg-img bg-cat"></div>
          <span class="hero-img-label">−47% к 3-й неделе</span>
        </div>
        <div class="hero-img-wrap">
          <div class="bg-img bg-jar"></div>
          <span class="hero-img-label">30 дней курса</span>
        </div>
      </div>
    </section>

    <!-- STATS STRIP -->
    <div class="strip">
      <div class="strip-inner">
        <div class="strip-stat"><div class="num">−47%</div><div class="lbl">аллергена в среднем (3 нед.)</div></div>
        <div class="strip-div"></div>
        <div class="strip-stat"><div class="num">3–6</div><div class="lbl">недель до устойчивого эффекта</div></div>
        <div class="strip-div"></div>
        <div class="strip-stat"><div class="num">127</div><div class="lbl">довольных семей</div></div>
        <div class="strip-div"></div>
        <div class="strip-stat"><div class="num">100%</div><div class="lbl">натуральный состав</div></div>
      </div>
    </div>

    <!-- FILTERS + FACTS GRID -->
    <section id="facts">
      <div class="filters-section">
        <div class="wrap">
          <div class="filters-top">
            <h2>Интересные факты<br/>об аллергии и кошках</h2>
            <div class="search-wrap">
              <svg class="search-ico" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <circle cx="11" cy="11" r="8"/>
                <path d="M21 21l-4.35-4.35"/>
              </svg>
              <input type="search" id="searchInput" placeholder="Поиск фактов…" />
            </div>
          </div>

          <div class="time-filters" id="timeFilters">
            {timeFilters.map((f) => (
              <button class={`time-btn${f.value === 'all' ? ' active' : ''}`} data-time={f.value} type="button">{f.label}</button>
            ))}
          </div>

          <div class="cat-filters" id="catFilters">
            {catFilters.map((f) => (
              <button class={`cat-btn${f.value === 'all' ? ' active' : ''}`} data-cat={f.value} type="button">
                <span class="ico">{f.ico}</span>{f.label}
              </button>
            ))}
          </div>
        </div>
      </div>

      <div class="cards-section">
        <div class="wrap">
          <div class="cards-grid stagger" id="cardsGrid">
            {facts.map((card) => (
              <div class="fact-card" data-cat={card.cat} data-time={card.time} data-idx={card.idx}>
                <div class="card-img">
                  <div class={`card-img-inner ${card.bg}`}>
                    <Fragment set:html={ICONS[card.icon] ?? ''} />
                  </div>
                  <span class="card-num">Факт №{card.idx + 1}</span>
                </div>
                <div class="card-body">
                  <div class="card-cat"><span>{card.catIcon}</span>{card.catLabel}</div>
                  <div class="card-title">{card.title}</div>
                  <div class="card-text">{card.text}</div>
                </div>
                <div class="card-foot">
                  <div class="card-time">⏱ {card.time} мин</div>
                  <span class="card-tag">{card.tag}</span>
                </div>
              </div>
            ))}
          </div>

          <div id="noResults" class="no-results" style="display:none">
            <div class="icon">🔍</div>
            <h3>Ничего не найдено</h3>
            <p>Попробуйте другой запрос или сбросьте фильтры</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SLIDER (how it works) -->
    <section class="slider-section" id="how">
      <div class="slider-label reveal">
        <span class="eyebrow">Как работает</span>
        <h2>Путь от миски до облегчения</h2>
      </div>

      <div class="slider-track-wrap">
        <div class="slider-track" id="sliderTrack">
          {slides.map((s) => (
            <div class="slide-card">
              <div class={`slide-img ${s.bg}`}>
                <Fragment set:html={ICONS[s.icon] ?? ''} />
              </div>
              <div class="slide-body">
                <h4>{s.title}</h4>
                <p>{s.text}</p>
                <span class="slide-tag">{s.tag}</span>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="slider-nav">
        <button class="sl-btn" id="slPrev" type="button" aria-label="Назад">←</button>
        <button class="sl-btn" id="slNext" type="button" aria-label="Вперёд">→</button>
      </div>
    </section>

    <!-- BUY SECTION -->
    <section class="buy-section" id="buy">
      <div class="wrap">
        <div class="buy-inner">
          <div class="buy-text reveal">
            <h2>AllerCat 100&nbsp;г — курс на&nbsp;месяц</h2>
            <p>Порошковая кормовая добавка с&nbsp;IgY-антителами. Связывает аллерген Fel&nbsp;d&nbsp;1 ещё в&nbsp;слюне кошки и&nbsp;помогает снижать его активный уровень на&nbsp;шерсти — без влияния на&nbsp;вкус корма и&nbsp;самочувствие животного.</p>
            <div class="buy-price">
              <span class="price-big">2&nbsp;690&nbsp;₽</span>
              <span class="price-old">3&nbsp;200&nbsp;₽</span>
              <span class="price-badge">−16%</span>
            </div>
            <div style="display:flex;gap:12px;margin-bottom:32px;flex-wrap:wrap">
              <button class="btn btn-p" id="buyBtn" type="button">В корзину</button>
              <a class="btn btn-s" href="#facts">Подробнее</a>
            </div>
            <p style="color:var(--muted);font-size:.88rem;margin-bottom:16px;font-weight:600">🛒 Купить в маркетплейсах:</p>
            <div class="buy-shops">
              {shops.map((s) => (
                <div class="shop-tile">
                  <div class="shop-ico">{s.ico}</div>
                  <div class="shop-name">{s.name}</div>
                </div>
              ))}
            </div>
          </div>
          <div class="buy-img reveal">
            <div class="bg-img bg-cat"></div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer contact={data.contact} />

  <!-- ARTICLE MODAL -->
  <div class="art-modal" id="artModal">
    <div class="art-inner" id="artInner">
      <!-- rendered by JS -->
    </div>
  </div>

  <!-- CART DRAWER -->
  <div class="backdrop" id="backdrop"></div>
  <aside class="drawer" id="drawer" aria-label="Корзина">
    <div class="drawer-head">
      <h3>Корзина</h3>
      <button class="drawer-close" id="drawerClose" type="button" aria-label="Закрыть">✕</button>
    </div>
    <div class="drawer-body" id="drawerBody">
      <div class="drawer-empty">Корзина пуста<br/><small>Добавьте AllerCat, чтобы продолжить</small></div>
    </div>
    <div class="drawer-foot">
      <div class="drawer-total"><span>Итого</span><span id="drawerTotal">0&nbsp;₽</span></div>
      <button class="btn btn-p" style="width:100%;justify-content:center" type="button">Оформить заказ</button>
    </div>
  </aside>

  <div class="toast" id="toast"></div>

  <script is:inline define:vars={{ facts, ICONS }}>
    // Cards interactivity
    const CARDS = Array.from(document.querySelectorAll('.fact-card'));

    // ─── FILTERS ─────────────────────────────────────────────
    let activeCat = 'all', activeTime = 'all', searchQ = '';

    function filterCards() {
      let any = false;
      CARDS.forEach((c) => {
        const cat = c.dataset.cat;
        const time = parseInt(c.dataset.time);
        const text = c.innerText.toLowerCase();
        const matchCat  = activeCat === 'all' || cat === activeCat;
        const matchTime = activeTime === 'all' || time === parseInt(activeTime);
        const matchQ    = !searchQ || text.includes(searchQ);
        const show = matchCat && matchTime && matchQ;
        c.style.display = show ? '' : 'none';
        if (show) any = true;
      });
      const noResults = document.getElementById('noResults');
      if (noResults) noResults.style.display = any ? 'none' : 'block';
    }

    document.querySelectorAll('.cat-btn').forEach((b) => {
      b.addEventListener('click', () => {
        document.querySelectorAll('.cat-btn').forEach((x) => x.classList.remove('active'));
        b.classList.add('active');
        activeCat = b.dataset.cat;
        filterCards();
      });
    });

    document.querySelectorAll('.time-btn').forEach((b) => {
      b.addEventListener('click', () => {
        document.querySelectorAll('.time-btn').forEach((x) => x.classList.remove('active'));
        b.classList.add('active');
        activeTime = b.dataset.time;
        filterCards();
      });
    });

    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQ = e.target.value.toLowerCase().trim();
        filterCards();
      });
    }

    // ─── ARTICLE MODAL ────────────────────────────────────────
    const bgGradients = {
      bg1:  'linear-gradient(135deg, #F5EDD6 0%, #E8C27A 100%)',
      bg2:  'linear-gradient(135deg, #E8F0E8 0%, #8BA888 100%)',
      bg3:  'linear-gradient(135deg, #FDE8E0 0%, #C4694F 100%)',
      bg4:  'linear-gradient(135deg, #EFE3C0 0%, #D4A843 100%)',
      bg5:  'linear-gradient(135deg, #E8F0E8 0%, #6B8A68 100%)',
      bg6:  'linear-gradient(135deg, #F5EDD6 0%, #9A6B45 100%)',
      bg7:  'linear-gradient(135deg, #F5EDD6 0%, #C4694F 100%)',
      bg8:  'linear-gradient(135deg, #E8F4EE 0%, #6B8A68 100%)',
      bg9:  'linear-gradient(135deg, #FBF0E0 0%, #B8892A 100%)',
      bg10: 'linear-gradient(135deg, #F5EDD6 0%, #7B4F2E 100%)',
      bg11: 'linear-gradient(135deg, #FDE8E0 0%, #A5553E 100%)',
      bg12: 'linear-gradient(135deg, #EFE3C0 0%, #6B8A68 100%)',
    };

    function openArticle(idx) {
      const a = facts[idx];
      if (!a) return;
      const inner = document.getElementById('artInner');
      inner.innerHTML = `
        <div class="art-hero" style="background:${bgGradients[a.bg] || bgGradients.bg1}">
          <button class="art-close-btn" id="artClose" type="button" aria-label="Закрыть">✕</button>
          <div class="art-hero-emoji">${ICONS[a.icon] || ''}</div>
          <div class="art-meta">
            <span class="art-cat-badge">${a.catIcon} ${a.catLabel}</span>
            <span class="art-time-badge">⏱ ${a.time} мин чтения</span>
          </div>
          <h2>${a.title}</h2>
        </div>
        <div class="art-body">
          <p>${a.text}</p>
          <p>Это один из ${facts.length} фактов в нашей базе. AllerCat — российская кормовая добавка на основе IgY-антител: они связывают аллерген Fel d 1 в слюне кошки. По данным Satyaraj et al. (2019) среднее снижение активного Fel d 1 на шерсти составляет 47% к 3-й неделе ежедневного применения.</p>
        </div>
        <div class="art-foot">
          <small>Кормовая добавка AllerCat. Не является лекарственным средством.</small>
          <button class="btn btn-p" id="artBuy" type="button">Купить — 2&nbsp;690&nbsp;₽</button>
          <button class="btn btn-s" id="artClose2" type="button">Закрыть</button>
        </div>`;
      document.getElementById('artModal').classList.add('open');
      document.body.style.overflow = 'hidden';
      document.getElementById('artClose').onclick  = closeArticle;
      document.getElementById('artClose2').onclick = closeArticle;
      document.getElementById('artBuy').onclick = () => { closeArticle(); addToCart(); };
    }
    function closeArticle() {
      document.getElementById('artModal').classList.remove('open');
      document.body.style.overflow = '';
    }
    document.getElementById('artModal').addEventListener('click', (e) => {
      if (e.target === document.getElementById('artModal')) closeArticle();
    });

    CARDS.forEach((c) => {
      c.addEventListener('click', () => openArticle(parseInt(c.dataset.idx)));
    });

    // ─── CART ────────────────────────────────────────────────
    let cart = [];
    const drawer   = document.getElementById('drawer');
    const backdrop = document.getElementById('backdrop');

    function openDrawer()  { drawer.classList.add('open');    backdrop.classList.add('open'); }
    function closeDrawer() { drawer.classList.remove('open'); backdrop.classList.remove('open'); }

    document.getElementById('cartBtn').addEventListener('click', openDrawer);
    document.getElementById('drawerClose').addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);

    function addToCart() {
      const existing = cart.find((i) => i.id === 'allercat');
      if (existing) existing.qty++;
      else cart.push({ id: 'allercat', name: 'AllerCat 100 г', price: 2690, qty: 1 });
      renderCart();
      showToast('Добавлено в корзину');
    }
    document.getElementById('buyBtn').addEventListener('click', () => { addToCart(); openDrawer(); });

    function renderCart() {
      const count = cart.reduce((s, i) => s + i.qty, 0);
      document.getElementById('cartCount').textContent = count;
      const body = document.getElementById('drawerBody');
      if (!cart.length) {
        body.innerHTML = '<div class="drawer-empty">Корзина пуста<br/><small>Добавьте AllerCat, чтобы продолжить</small></div>';
        document.getElementById('drawerTotal').textContent = '0 ₽';
        return;
      }
      body.innerHTML = cart.map((item, idx) => `
        <div class="cart-item">
          <div class="ci-img bg-img bg-jar"></div>
          <div class="ci-info"><strong>${item.name}</strong><small>${item.qty} шт × ${item.price.toLocaleString('ru')} ₽</small></div>
          <div>
            <div class="ci-price">${(item.qty * item.price).toLocaleString('ru')} ₽</div>
            <button style="font-size:.75rem;color:var(--muted);margin-top:4px" data-rm="${idx}" type="button">удалить</button>
          </div>
        </div>`).join('');
      body.querySelectorAll('[data-rm]').forEach((btn) => {
        btn.addEventListener('click', () => {
          cart.splice(parseInt(btn.dataset.rm), 1);
          renderCart();
        });
      });
      const total = cart.reduce((s, i) => s + i.qty * i.price, 0);
      document.getElementById('drawerTotal').textContent = total.toLocaleString('ru') + ' ₽';
    }

    // ─── TOAST ───────────────────────────────────────────────
    let toastT;
    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = '✓ ' + msg;
      t.classList.add('show');
      clearTimeout(toastT);
      toastT = setTimeout(() => t.classList.remove('show'), 2400);
    }

    // ─── SLIDER ──────────────────────────────────────────────
    const track = document.getElementById('sliderTrack');
    let slIdx = 0;
    const SLIDE_W = 320;

    function updateSlider() {
      if (!track) return;
      const max = track.children.length - Math.floor(track.parentElement.offsetWidth / SLIDE_W);
      slIdx = Math.max(0, Math.min(slIdx, max));
      track.style.transform = `translateX(-${slIdx * SLIDE_W}px)`;
    }
    const slNext = document.getElementById('slNext');
    const slPrev = document.getElementById('slPrev');
    if (slNext) slNext.addEventListener('click', () => { slIdx++; updateSlider(); });
    if (slPrev) slPrev.addEventListener('click', () => { slIdx = Math.max(0, slIdx - 1); updateSlider(); });
    window.addEventListener('resize', updateSlider);

    // ─── SCROLL REVEAL ───────────────────────────────────────
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add('on'); });
    }, { threshold: 0.05 });
    document.querySelectorAll('.reveal,.stagger').forEach((el) => obs.observe(el));
    setTimeout(() => {
      document.querySelectorAll('.reveal,.stagger').forEach((el) => el.classList.add('on'));
    }, 400);
  </script>

</BaseLayout>
