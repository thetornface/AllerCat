---
import '../styles/global.css';

const {
  title = 'AllerCat',
  description = 'AllerCat — ежедневная добавка к корму, которая помогает снижать активный Fel d 1, главный кошачий аллерген.',
  ogImage = '/assets/images/og-image.jpg',
  noIndex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://allercat.ru');
---
<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6ecda" />
    {noIndex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalURL.href} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/assets/icons/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
  </head>
  <body>
    <a class="skip-link" href="#content">Перейти к содержимому</a>
    <slot />
  </body>
</html>
