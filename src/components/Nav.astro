---
const isHome = Astro.url.pathname === '/';
const link = (anchor: string) => (isHome ? anchor : `/${anchor}`);
const cartHref = isHome ? '#buy' : '/#buy';
---

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="AllerCat — на главную">
      <div class="bg-logo" role="img" aria-label="AllerCat"></div>
      <span class="nav-logo-text">AllerCat</span>
    </a>

    <div class="nav-links" id="navLinks">
      <a href={link('#facts')}>Факты</a>
      <a href={link('#how')}>Как работает</a>
      <a href={link('#faq')}>FAQ</a>
      <a href={link('#buy')}>Предзаказ</a>
    </div>

    <div class="nav-right">
      {isHome ? (
        <button class="nav-cart" id="cartBtn" type="button" aria-label="Оформить предзаказ">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
          <span class="cart-badge">Предзаказ</span>
        </button>
      ) : (
        <a class="nav-cart" href={cartHref} aria-label="Перейти к предзаказу">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6L9 17l-5-5"/>
          </svg>
          <span class="cart-badge">Предзаказ</span>
        </a>
      )}
      <button class="mob-menu" id="mobMenu" type="button" aria-label="Меню">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <path d="M3 6h18M3 12h18M3 18h18"/>
        </svg>
      </button>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const mobBtn = document.getElementById('mobMenu');
  const navLinks = document.getElementById('navLinks');
  if (mobBtn && navLinks) {
    mobBtn.addEventListener('click', () => {
      navLinks.classList.toggle('open');
    });
    // Close menu on link click
    navLinks.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', () => navLinks.classList.remove('open'));
    });
  }
</script>
