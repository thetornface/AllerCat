---
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { getEntry } from 'astro:content';

const { title, description, eyebrow = 'Юридическая информация', intro } = Astro.props;

const homeEntry = await getEntry('home', 'home');
const contact = homeEntry!.data.contact;
---

<BaseLayout title={`${title} — AllerCat`} description={description ?? title}>
  <Nav />
  <main id="content" class="legal-page">
    <section class="legal-hero">
      <span class="eyebrow">{eyebrow}</span>
      <h1 style="margin-top: 0.5rem; font-size: clamp(2rem, 5vw, 3rem);">{title}</h1>
      {intro && <p style="max-width: 640px; color: var(--muted); font-size: 1.05rem; line-height: 1.6; margin-top: 0.75rem;">{intro}</p>}
      <div class="legal-alert">
        Актуальные условия оплаты, доставки и возврата публикуются в действующей редакции документов
        и подтверждаются при заказе.
      </div>
    </section>

    <article class="legal-content">
      <slot />
    </article>
  </main>
  <Footer contact={contact} />
</BaseLayout>
